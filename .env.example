# ============================================================
#  CONTOH ENVIRONMENT VARIABLES — Task Tracker (Vercel)
#  Salin nilai-nilai ini ke Vercel: Project Settings > Environment Variables
#  JANGAN commit file .env asli ke Git.
# ============================================================

# 1) ID Google Spreadsheet tujuan (sama dengan yang dipakai Apps Script).
#    Ambil dari URL: https://docs.google.com/spreadsheets/d/<INI_ID_NYA>/edit
SPREADSHEET_ID=1AbcDEfgHIjkLMnopQRstuVWxyz1234567890abcd

# 2) Kredensial Service Account (isi SELURUH JSON dalam SATU baris).
#    Didapat saat membuat key JSON service account di Google Cloud.
#    Tips: buka file JSON, copy semua isinya, tempel sebagai satu nilai.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"xxx","private_key_id":"xxx","private_key":"-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n","client_email":"task-tracker@xxx.iam.gserviceaccount.com","client_id":"xxx","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/task-tracker%40xxx.iam.gserviceaccount.com"}

# 3) (Opsional) Daftar nama manager, pisahkan dengan koma.
#    Manager bisa melihat SEMUA task lintas PIC. Default: Nynda
MANAGERS=Nynda

# 4) (Opsional) Selisih zona waktu server -> waktu lokal (menit).
#    Default 420 = WIB (UTC+7). WITA=480, WIT=540.
TIMEZONE_OFFSET_MINUTES=420
